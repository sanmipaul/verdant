# Your deployer wallet private key (with 0x prefix)
PRIVATE_KEY=0x

# Your deployer wallet address
DEPLOYER_ADDRESS=0x

# The Cloudflare agent's wallet address (will be authorized to trigger payouts)
AGENT_WALLET_ADDRESS=0x

# Set to true for Celo mainnet, false for Alfajores testnet
MAINNET=false

# Get a free API key at https://celoscan.io/myapikey (for contract verification)
CELOSCAN_API_KEY=
